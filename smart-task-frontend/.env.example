# Copy to .env for local `ng serve` (Vite loads VITE_* from .env).
# Local API gateway:
#   VITE_API_URL=http://localhost:8080
# EC2 / production: set to your instance public DNS or IP (changes after stop/start unless Elastic IP):
#   VITE_API_URL=http://YOUR_PUBLIC_IP_OR_DNS:8080
VITE_API_URL=http://localhost:8080

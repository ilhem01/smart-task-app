# Optional: override API gateway URL at build time (e.g. API on another host than the SPA).
# If unset, the app uses the same hostname as the page with port 8080 (good for EC2: SPA :3000, API :8080).
# A baked-in localhost URL is ignored in the browser so public deploys are not stuck on loopback.
# Local dev: leave unset or VITE_API_URL=http://localhost:8080
# VITE_API_URL=http://localhost:8080

# Copy to `.env` in the same directory as `docker-compose.yml` on EC2, or export before `docker compose up`.
# Use the instance's current public IPv4 and port where the SPA is served (e.g. 3000).
# Tip: attach an Elastic IP so this value does not change after stop/start.
CORS_ALLOWED_ORIGIN=http://YOUR_PUBLIC_IP:3000
